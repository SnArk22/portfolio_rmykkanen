---
import Layout from "@/layouts/Layout.astro";
import Text from "@/components/Text.astro";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
  CardFooter,
  CardMedia,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Carousel, CarouselSlide } from "@/components/ui/carousel";

import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export const getStaticPaths = async () => {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { project: project.id },
    props: { project },
  }));
};

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/**/*.{webp,jpg,png}",
  { eager: true },
);

const { project } = Astro.props;
const { Content } = await render(project);

const slug = project.id;

if (!allImages[`/src/assets/projects/${slug}/featured.webp`]) {
  throw new Error(
    `No featured image found for project ${slug}. Add a an image titled 'featured.webp' to folder '/src/assets/projects/${slug}/'`,
  );
}

const featuredImage =
  allImages[`/src/assets/projects/${slug}/featured.webp`].default;

const galleryImages = Object.entries(allImages)
  .filter(
    ([path]) =>
      path.includes(`/projects/${slug}/`) && !path.endsWith("featured.webp"),
  )
  .map(([_, loader]) => loader.default);
---

<Layout>
  <Card
    class:list={"w-full gap-8 bg-card/20 border-secondary border flex-row p-8!"}
  >
    <CardMedia class="flex-1">
      <Image src={featuredImage} alt="project image" />
    </CardMedia>
    <div class="flex-1 flex flex-col self-center">
      <CardHeader class:list={"px-0"}>
        <CardTitle>
          <Text as="h1" variant="majorHeading">
            {project.data.title}
          </Text>
        </CardTitle>
        <CardDescription>
          <Text>
            {project.data.description}
          </Text>
        </CardDescription>
      </CardHeader>
      <CardContent class:list={"p-0"}>
        <ul class="flex flex-col gap-2">
          <li>
            <Text>Creator: {project.data.creator}</Text>
          </li>
          <li>
            <Text>Collaborators: {project.data.collaborators ?? "None"}</Text>
          </li>
          <li>
            {
              project.data.completed && (
                <Text>Project Completed on {project.data.completed}</Text>
              )
            }
          </li>

          <li class="flex gap-4">
            {
              project.data.tags &&
                project.data.tags.map((tag) => (
                  <Badge>
                    <a href=`/tag/${tag}`>{tag}</a>
                  </Badge>
                ))
            }
          </li>
        </ul>
      </CardContent>
    </div>
  </Card>
  <Content />

  {
    galleryImages.length > 0 && (
      <Carousel class="gap-4 p-2" align="center">
        {galleryImages.map((image) => (
          <CarouselSlide>
            <Image
              src={image}
              alt={"project gallery image"}
              class="w-120 h-96 object-cover rounded-lg"
            />
          </CarouselSlide>
        ))}
      </Carousel>
    )
  }
</Layout>
